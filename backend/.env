# PostgreSQL - настройки для подключения к базе данных
POSTGRES_DB=kraeved
POSTGRES_USER=kraeved_user
POSTGRES_PASSWORD=kraeved_password

# Backend API - переменные для самого FastAPI приложения

# URL для подключения к БД из контейнера API
DATABASE_URL=postgresql+asyncpg://kraeved_user:kraeved_password@postgres:5432/kraeved

# URL для подключения к Redis из контейнера API
REDIS_URL=redis://redis:6379

# Ваш токен Telegram бота, который вы получаете у @BotFather
BOT_TOKEN=8288368777:AAGxdyBMJ6xjGeZVslKglU-DzI2N16CLgws

# --- JWT Settings ---
# Секретный ключ для подписи JWT. МОЖЕТ совпадать с BOT_TOKEN для простоты, но в проде лучше использовать разный
SECRET_KEY=8288368777:AAGxdyBMJ6xjGeZVslKglU-DzI2N16CLgws
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30