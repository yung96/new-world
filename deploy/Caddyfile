{
    email {env.ACME_EMAIL}
}

apikraeved.tw1.su {
    encode zstd gzip

    reverse_proxy kraeved_api:8000 {
        header_up X-Forwarded-Proto {scheme}
        header_up Host {host}
        # E2E /ivan-alt/local-routes/test-run и LLM могут отвечать долго — иначе обрыв «сеть потеряна»
        transport http {
            read_timeout 300s
            write_timeout 300s
        }
    }
}

{$DOMAIN:localhost} {
    encode zstd gzip

    # --- API proxy ---
    handle /api/* {
        reverse_proxy api:8000 {
            header_up X-Forwarded-Proto {scheme}
            header_up Host {host}
            transport http {
                read_timeout 300s
                write_timeout 300s
            }
        }
    }

    # --- SPA frontend ---
    handle {
        root * /srv
        file_server
        try_files {path} /index.html
    }
}
